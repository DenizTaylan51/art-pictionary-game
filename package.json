{
  "name": "art-pictionary-game",
  "version": "1.0.0",
  "description": "Multiplayer Pictionary game with famous artworks",
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "dev": "npm run dev:server",
    "dev:server": "nodemon server/index.js",
    "dev:client": "cd client && npm run dev",
    "dev:all": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "cd client && npm run build",
    "start": "node server/index.js",
    "server": "node server/index.js"
  },
  "keywords": [
    "pictionary",
    "multiplayer",
    "canvas",
    "drawing",
    "game"
  ],
  "author": "DenizTaylan51",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "concurrently": "^8.2.2"
  }
}
